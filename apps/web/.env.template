# apps/web/.env.local — copy to .env.local for local dev / set same vars in Vercel

NEXT_PUBLIC_TASKPAY_ADDRESS_SEPOLIA=
NEXT_PUBLIC_DEMO_STORAGE_MODE=false

NEXT_PUBLIC_SUPABASE_URL=
# Base URL only, e.g. https://abcdefgh.supabase.co (not /rest/v1/)
