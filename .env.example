# TaskPay environment variables

# Celo Sepolia TaskPay contract (set after deploy)
NEXT_PUBLIC_TASKPAY_ADDRESS_SEPOLIA=

# Celo Mainnet TaskPay contract (set after mainnet deploy)
NEXT_PUBLIC_TASKPAY_ADDRESS_MAINNET=

# Supabase (photo evidence only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Deployer private key (server-side / Foundry only — never commit real keys)
PRIVATE_KEY=

# Celoscan API key for contract verification
CELOSCAN_API_KEY=
